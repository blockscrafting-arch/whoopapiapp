# PostgreSQL (async для приложения)
DATABASE_URL=postgresql+asyncpg://whoop:whoop@localhost:5432/whoop_pwa
# Тот же DSN без +asyncpg — для Alembic (синхронно)
DATABASE_URL_SYNC=postgresql://whoop:whoop@localhost:5432/whoop_pwa

# WHOOP OAuth (из Developer Dashboard)
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
# Должен совпадать с зарегистрированным в WHOOP (HTTPS)
WHOOP_REDIRECT_URI=https://your-domain.example/auth/callback

# Секреты приложения (сгенерировать случайные длинные строки)
SESSION_SECRET_KEY=change-me-min-32-chars-random-secret-key-here
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# Опционально
# DEBUG=true — cookie сессии без Secure (только для локального http://)
DEBUG=false
# Через запятую, если фронт на другом origin
CORS_ORIGINS=
